# Senha para acessar o proxy remoto (obrigatório)
MIMO_PROXY_TOKEN=cole-sua-senha-aqui

# Onde o mimo serve está rodando
MIMO_SERVER_URL=http://127.0.0.1:7788

# Senha que você definiu como MIMOCODE_SERVER_PASSWORD ao rodar `mimo serve`
MIMO_SERVER_PASSWORD=cole-a-senha-do-mimo-serve-aqui

# Porta/host expostos pelo proxy
MIMO_PROXY_PORT=8787
MIMO_PROXY_HOST=0.0.0.0

# Modelo padrao para /v1/chat/completions quando o cliente nao envia (opcional)
MIMO_PROXY_MODEL=mimo-auto

# Modo de operacao:
#   raw   (default) -> LLM cru: desativa as ferramentas internas do MiMo e
#                      repassa o system prompt do cliente. Use com Roo Code,
#                      Cline, etc., para que o CLIENTE dirija as proprias tools.
#   agent           -> o agente do MiMo executa as proprias ferramentas
#                      (read/edit/bash/...) e o uso delas aparece como
#                      reasoning_content no streaming.
MIMO_PROXY_MODE=raw

# Se "false", desativa a exigencia de X-API-Key (apenas uso local/trust — nao exponha na internet)
MIMO_PROXY_REQUIRE_AUTH=true

# Origem permitida para CORS (default: "*" — qualquer origem)
# Para producao, defina o dominio exato: https://meu-app.com
MIMO_PROXY_CORS_ORIGIN=*
